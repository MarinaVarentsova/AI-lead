# =============================================
# AI Квалификатор ИНОБР — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- Database (PostgreSQL / Supabase Postgres) ----
# Direct PostgreSQL connection string.
# For Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Supabase (Backend — server-side ONLY) ----
# Service Role Key — grants full DB access bypassing RLS.
# NEVER expose this to the frontend or browser.
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---- Supabase (Frontend — browser-safe) ----
# These are safe to expose in client-side code (VITE_ prefix makes them available).
# Supabase Dashboard → Settings → API → Project URL + anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ---- Session ----
# Random secret for signing sessions. Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# ---- Server ----
# Port the Express server listens on (Replit/Vercel injects this automatically)
PORT=8080

# ---- Logging ----
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ---- Knowledge Base ----
# Source of knowledge base data: "file" or "database"
KNOWLEDGE_BASE_SOURCE=file
